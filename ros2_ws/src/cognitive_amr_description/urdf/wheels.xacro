<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ══ DRIVE WHEELS (left and right sides) ═════════════ -->
  <xacro:macro name="drive_wheel" params="side y_reflect joint_origin_y">

    <link name="${side}_wheel_link">
      <visual>
        <!-- rpy pi/2 rotates cylinder to lie on its side = disc shape -->
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <geometry>
          <cylinder radius="0.075" length="0.05"/>
        </geometry>
        <material name="wheel_dark">
          <color rgba="0.08 0.08 0.08 1.0"/>
        </material>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <geometry>
          <cylinder radius="0.075" length="0.05"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="2.5"/>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <inertia
          ixx="0.00286" ixy="0" ixz="0"
          iyy="0.00286" iyz="0"
          izz="0.00703"/>
      </inertial>
    </link>

    <joint name="${side}_wheel_joint" type="continuous">
      <parent link="base_link"/>
      <child  link="${side}_wheel_link"/>
      <!-- x=0 (axle at center length)
           y=±0.30 (just outside chassis edge 0.325 - half wheel width)
           z=-0.075 (drop to ground level in base_link frame) -->
      <origin xyz="0 ${joint_origin_y} -${drive_wheel_radius}" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <dynamics damping="0.01" friction="0.1"/>
      <limit effort="100" velocity="10.0"/>
    </joint>

    <gazebo reference="${side}_wheel_link">
      <material>Gazebo/Black</material>
      <mu1>1.5</mu1>
      <mu2>1.0</mu2>
      <kp>500000</kp>
      <kd>10</kd>
      <minDepth>0.001</minDepth>
    </gazebo>

  </xacro:macro>

  <!-- ══ CASTER WHEELS (front and rear spheres) ══════════ -->
  <xacro:macro name="caster_wheel" params="side x_offset">

    <link name="${side}_caster_bracket_link">
      <inertial>
        <mass value="0.05"/>
        <inertia ixx="0.0001" ixy="0" ixz="0"
                 iyy="0.0001" iyz="0" izz="0.0001"/>
      </inertial>
    </link>

    <joint name="${side}_caster_bracket_joint" type="fixed">
      <parent link="base_link"/>
      <child  link="${side}_caster_bracket_link"/>
      <!-- x_offset: front=+0.30, rear=-0.30
           z=-0.075 drops to ground level, then +0.030 up to sphere center -->
      <origin xyz="${x_offset} 0 ${-(robot_height/2 + drive_wheel_radius - caster_wheel_radius)}" rpy="0 0 0"/>
    </joint>

    <link name="${side}_caster_wheel_link">
      <visual>
        <geometry>
          <sphere radius="0.030"/>
        </geometry>
        <material name="wheel_dark"/>
      </visual>
      <collision>
        <geometry>
          <sphere radius="0.030"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="0.3"/>
        <inertia
          ixx="0.000108" ixy="0" ixz="0"
          iyy="0.000108" iyz="0"
          izz="0.000108"/>
      </inertial>
    </link>

    <joint name="${side}_caster_wheel_joint" type="fixed">
      <parent link="${side}_caster_bracket_link"/>
      <child  link="${side}_caster_wheel_link"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </joint>

    <!-- Zero friction — sphere rolls freely in all directions -->
    <gazebo reference="${side}_caster_wheel_link">
      <material>Gazebo/DarkGray</material>
      <mu1>0.0</mu1>
      <mu2>0.0</mu2>
      <kp>100000</kp>
      <kd>1</kd>
    </gazebo>

  </xacro:macro>

</robot>